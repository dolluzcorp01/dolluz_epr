# ─────────────────────────────────────────────────────────────
#  Dolluz EPR Portal — Environment Variables
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────
PORT=4321
NODE_ENV=development

# ── MySQL Database ───────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password_here
DB_NAME=dolluz_epr

# ── JWT Secrets ───────────────────────────────────────────────
JWT_ADMIN_SECRET=change_this_to_a_long_random_string
JWT_STAKEHOLDER_SECRET=change_this_to_another_long_random_string
JWT_ADMIN_EXPIRES_IN=8h
JWT_STAKEHOLDER_EXPIRES_IN=2h

# ── Email / SMTP ───────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key_here

EMAIL_FROM_NAME=Dolluz EPR Portal
EMAIL_FROM_ADDRESS=noreply@dolluz.com
EMAIL_ADMIN_ADDRESS=admin@dolluz.com

# ── OTP Configuration ─────────────────────────────────────────
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6

# ── File Uploads ──────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ── Frontend URL (for CORS & email links) ─────────────────────
FRONTEND_URL=http://localhost:3000
PORTAL_URL=http://localhost:3000
STAKEHOLDER_FORM_URL=http://localhost:3000/review

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
OTP_RATE_LIMIT_MAX=5

# ── Session & Security ────────────────────────────────────────
BCRYPT_ROUNDS=12
SESSION_TIMEOUT_MINUTES=480
AUTO_LOGOUT_ON_CLOSE=false
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30
